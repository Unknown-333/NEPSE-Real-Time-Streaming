# =============================================================
# NEPSE Real-Time Streaming Pipeline - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# --- Kafka Configuration ---
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_RAW=nepse-raw-ticks
KAFKA_TOPIC_AGGREGATED=nepse-aggregated

# --- TimescaleDB (PostgreSQL) Configuration ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nepse_streaming
POSTGRES_USER=nepse_user
POSTGRES_PASSWORD=changeme_in_production

# --- Data Generator Configuration ---
# Replay speed multiplier (100 = 100x real-time speed)
REPLAY_SPEED=100
# Number of trading days to generate
TRADING_DAYS=250
# Batch size for Kafka producer
PRODUCER_BATCH_SIZE=500

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
